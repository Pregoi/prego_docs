---
/**
 * Kinde-style header: [ Prego logo ] [ Docs ] … [ Manual | API | Log in | Theme | Search ]
 * Logo: prego-black (light), prego_logo_white (dark) per PLAN-prego-docs-kinde-visual-spec.
 */
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components?.Search !== '@astrojs/starlight/components/Search.astro';

const siteTitleHref = Astro.props.siteTitleHref ?? '/';
const LOGO_HREF = siteTitleHref;
const MANUAL_HREF = '/';
const API_HREF = '/api/overview/';
const LOGIN_HREF = 'https://beta.pregoi.com/login';
---

<div class="prego-header sl-flex">
  <div class="title-wrapper sl-flex">
    <a href={LOGO_HREF} class="logo-link sl-flex" aria-label="Prego home">
      <img class="logo-img logo-light" src="/logo-black.png" alt="Prego" width="120" height="28" />
      <img class="logo-img logo-dark" src="/logo-white.png" alt="Prego" width="120" height="28" />
      <span class="docs-label">Docs</span>
    </a>
  </div>
  <nav class="nav-links sl-flex" aria-label="Main">
    <a href={MANUAL_HREF} class="nav-link">Manual</a>
    <a href={API_HREF} class="nav-link">API</a>
    <a href={LOGIN_HREF} class="nav-link" rel="noopener noreferrer" target="_blank">Log in</a>
  </nav>
  <div class="sl-flex right-group">
    <ThemeSelect {...Astro.props} />
    {shouldRenderSearch && <Search {...Astro.props} />}
  </div>
</div>

<style>
  .prego-header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    overflow: hidden;
  }

  .logo-link {
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--sl-color-text);
  }
  .logo-link:hover {
    color: var(--sl-color-text-accent);
  }

  .logo-img {
    height: 28px;
    width: auto;
    max-height: 32px;
    object-fit: contain;
    flex-shrink: 0;
    display: block;
  }
  .logo-dark {
    display: none;
  }
  :global([data-theme='dark']) .logo-light,
  :global(.dark) .logo-light {
    display: none;
  }
  :global([data-theme='dark']) .logo-dark,
  :global(.dark) .logo-dark {
    display: block;
  }

  .docs-label {
    font-size: 1rem;
    font-weight: 700;
    color: #000000;
    white-space: nowrap;
  }
  :global([data-theme='dark']) .docs-label,
  :global(.dark) .docs-label {
    color: #ffffff;
  }

  .nav-links {
    gap: 1.625rem;   /* 기획서: 30% 확대 (1.25rem × 1.3) */
    align-items: center;
  }

  .nav-link {
    font-size: 1rem;    /* 기획서: 한 단계 확대 */
    font-weight: 700;    /* 기획서: bold */
    color: var(--sl-color-text);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--sl-color-text-accent);
  }

  .right-group {
    gap: 1rem;
    align-items: center;
  }

  @media (max-width: 50rem) {
    .nav-links {
      display: none;
    }
  }

  @media (min-width: 50rem) {
    .prego-header {
      display: grid;
      grid-template-columns: minmax(0, auto) 1fr auto;
      align-content: center;
    }
    .nav-links {
      justify-self: end;
    }
  }
</style>
