---
---

<div class="lg:sl-flex">
	{
		Astro.props.toc && (
			<aside class="right-sidebar-container">
				<div class="right-sidebar">
					<slot name="right-sidebar" />
				</div>
			</aside>
		)
	}
	<div class="main-pane"><slot /></div>
</div>

<style>
	.main-pane {
		isolation: isolate;
	}

	@media (min-width: 72rem) {
		.right-sidebar-container {
			order: 2;
			position: relative;
			/* 2:5:2 비율 — 우측 ToC 20rem 고정 */
			width: 20rem;
			min-width: 20rem;
			max-width: 20rem;
			flex-shrink: 0;
		}

		.right-sidebar {
			position: fixed;
			top: 0;
			padding-top: var(--sl-nav-height);
			width: 20rem;
			max-width: 20rem;
			height: 100vh;
			overflow-y: auto;
			scrollbar-width: none;
			box-sizing: border-box;
		}

		.main-pane {
			width: 100%;
		}

		:global([data-has-sidebar][data-has-toc]) .main-pane {
			--sl-content-margin-inline: auto 0;

			order: 1;
			/* 2:5:2 비율 — flex 컨테이너는 이미 좌측 20rem 제외됨, 우측 ToC 20rem만 제외 */
			width: calc(100% - 20rem);
		}
	}
</style>
