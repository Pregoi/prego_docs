---
import MobileMenuToggle from 'virtual:starlight/components/MobileMenuToggle';

const { hasSidebar } = Astro.props;

const BETA_HREF = 'https://beta.pregoi.com';
const CHAT_HREF = `${BETA_HREF}/#support`;
const DISCORD_HREF = 'https://discord.gg/prego';
const SLACK_HREF = 'https://prego.slack.com';

const HELP_LINKS = [
  { label: 'Browse the docs', href: '/' },
  { label: 'View our learning guides', href: '/get-started/' },
  { label: 'Request a feature', href: CHAT_HREF },
  { label: "See what's new", href: '/resources/' },
  { label: 'Read our blog', href: `${BETA_HREF}/blog` },
  { label: 'System status', href: `${BETA_HREF}/status` },
];
---

<div class="page sl-flex">
  <div class="header-strip" aria-hidden="true" />
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav class="sidebar" aria-label={Astro.locals.t('sidebarNav.accessibleLabel')}>
        <MobileMenuToggle {...Astro.props} />
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>

  <div class="ask-help-wrap">
    <button
      type="button"
      id="ask-help-btn"
      class="ask-help-button"
      aria-label="Ask Help"
      aria-expanded="false"
      aria-haspopup="dialog"
    >
      <span class="ask-help-label">Ask Help</span>
    </button>
    <div id="ask-help-popup" class="ask-help-popup" role="dialog" aria-labelledby="ask-help-title" aria-hidden="true">
      <h2 id="ask-help-title" class="ask-help-popup-title">Need a hand?</h2>
      <a href="/" class="ask-help-search" aria-label="Search documentation">
        <svg class="ask-help-search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
        <span>Search docs</span>
      </a>
      <div class="ask-help-links">
        {HELP_LINKS.map(({ label, href }) => (
          <a href={href} class="ask-help-link" target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            {label}
          </a>
        ))}
      </div>
      <p class="ask-help-communities-label">Join our communities</p>
      <div class="ask-help-communities">
        <a href={DISCORD_HREF} target="_blank" rel="noopener noreferrer" class="ask-help-community-icon" aria-label="Join Discord">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.077.077 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.077.077 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.078.078 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z" />
          </svg>
        </a>
        <a href={SLACK_HREF} target="_blank" rel="noopener noreferrer" class="ask-help-community-icon" aria-label="Join Slack">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#E01E5A" d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52z" />
            <path fill="#36C5F0" d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834z" />
            <path fill="#2EB67D" d="M15.165 18.956a2.528 2.528 0 0 1 2.52 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.521-2.522v-2.522h2.521z" />
            <path fill="#ECB22E" d="M8.834 18.956a2.528 2.528 0 0 1-2.521-2.522V15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v2.522a2.528 2.528 0 0 1-2.521 2.522z" />
          </svg>
        </a>
      </div>
      <a href={CHAT_HREF} class="ask-help-chat" target="_blank" rel="noopener noreferrer">
        <svg class="ask-help-chat-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z" />
        </svg>
        Chat with an advisor
      </a>
    </div>
  </div>
</div>

<script>
  (function () {
    const btn = document.getElementById('ask-help-btn');
    const popup = document.getElementById('ask-help-popup');
    if (!btn || !popup) return;

    function open() {
      popup.classList.add('is-open');
      popup.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
    }
    function close() {
      popup.classList.remove('is-open');
      popup.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
    }
    function toggle() {
      if (popup.classList.contains('is-open')) close();
      else open();
    }

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      toggle();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });

    document.addEventListener('mousedown', (e) => {
      if (!popup.contains(e.target) && !btn.contains(e.target)) close();
    });
  })();
</script>

<style>
  .page {
    flex-direction: column;
    min-height: 100vh;
  }

  .header-strip {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background-color: #374151;
    z-index: 11;
  }
  :global([data-theme='dark']) .header-strip,
  :global(.dark) .header-strip {
    background-color: #000000;
  }

  .header {
    z-index: var(--sl-z-index-navbar);
    position: fixed;
    inset-inline-start: 0;
    inset-block-start: 3px;
    width: 100%;
    height: var(--sl-nav-height);
    border-bottom: 1px solid var(--sl-color-hairline-shade);
    padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
    padding-inline-end: var(--sl-nav-pad-x);
    background-color: var(--sl-color-bg-nav);
  }

  :global([data-has-sidebar]) .header {
    padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
  }

  .sidebar-pane {
    visibility: var(--sl-sidebar-visibility, hidden);
    position: fixed;
    z-index: var(--sl-z-index-menu);
    inset-block-start: calc(3px + var(--sl-nav-height));
    inset-block-end: 0;
    inset-inline-start: 0;
    width: 100%;
    background-color: var(--sl-color-black);
    overflow-y: auto;
  }

  :global([aria-expanded='true']) ~ .sidebar-pane {
    --sl-sidebar-visibility: visible;
  }

  .sidebar-content {
    height: 100%;
    min-height: max-content;
    padding: 1rem var(--sl-sidebar-pad-x) 0;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 50rem) {
    .sidebar-content::after {
      content: '';
      padding-bottom: 1px;
    }
  }

  .main-frame {
    padding-top: calc(3px + var(--sl-nav-height) + var(--sl-mobile-toc-height));
    padding-inline-start: var(--sl-content-inline-start);
  }

  /* Ask Help 버튼 — 우측 하단, 회색 (beta.pregoi.com Ask Sales와 동일 기능) */
  .ask-help-wrap {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 999;
  }

  .ask-help-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    min-width: 44px;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    background-color: #6b7280;
    border: 1px solid #4b5563;
    border-radius: 9999px;
    cursor: pointer;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    transition: background-color 0.2s, box-shadow 0.2s;
  }
  .ask-help-button:hover {
    background-color: #4b5563;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }
  .ask-help-button:focus {
    outline: none;
    box-shadow: 0 0 0 2px #6b7280;
  }
  :global([data-theme='dark']) .ask-help-button,
  :global(.dark) .ask-help-button {
    background-color: #4b5563;
    border-color: #6b7280;
    color: #f9fafb;
  }
  :global([data-theme='dark']) .ask-help-button:hover,
  :global(.dark) .ask-help-button:hover {
    background-color: #6b7280;
  }

  .ask-help-label {
    white-space: nowrap;
  }

  /* 레이오버 팝업 — Need a hand? / Search docs / 링크 / Communities / Chat with an advisor */
  .ask-help-popup {
    position: fixed;
    bottom: 5.5rem;
    right: 1.5rem;
    z-index: 1000;
    width: calc(100vw - 3rem);
    max-width: 24rem;
    padding: 1.25rem;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    display: none;
  }
  .ask-help-popup.is-open {
    display: block;
  }
  :global([data-theme='dark']) .ask-help-popup,
  :global(.dark) .ask-help-popup {
    background-color: #111827;
    border-color: #374151;
  }

  .ask-help-popup-title {
    margin: 0 0 1rem;
    text-align: center;
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
  }
  :global([data-theme='dark']) .ask-help-popup-title,
  :global(.dark) .ask-help-popup-title {
    color: #f9fafb;
  }

  .ask-help-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding: 0.625rem 0.75rem;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
  }
  .ask-help-search:hover {
    background-color: #f3f4f6;
  }
  :global([data-theme='dark']) .ask-help-search,
  :global(.dark) .ask-help-search {
    background-color: #1f2937;
    border-color: #374151;
    color: #e5e7eb;
  }
  :global([data-theme='dark']) .ask-help-search:hover,
  :global(.dark) .ask-help-search:hover {
    background-color: #374151;
  }
  .ask-help-search-icon {
    flex-shrink: 0;
    color: #9ca3af;
  }

  .ask-help-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1rem;
    margin-bottom: 1rem;
  }
  .ask-help-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: #d1d5db;
  }
  .ask-help-link:hover {
    color: #059669;
    text-decoration-color: #059669;
  }
  :global([data-theme='dark']) .ask-help-link,
  :global(.dark) .ask-help-link {
    color: #d1d5db;
    text-decoration-color: #4b5563;
  }
  :global([data-theme='dark']) .ask-help-link:hover,
  :global(.dark) .ask-help-link:hover {
    color: #10b981;
    text-decoration-color: #10b981;
  }

  .ask-help-communities-label {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #6b7280;
  }
  :global([data-theme='dark']) .ask-help-communities-label,
  :global(.dark) .ask-help-communities-label {
    color: #9ca3af;
  }

  .ask-help-communities {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .ask-help-community-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background-color: #f3f4f6;
    border-radius: 0.5rem;
    color: #5865F2;
    transition: background-color 0.2s;
  }
  .ask-help-community-icon:hover {
    background-color: #e5e7eb;
  }
  :global([data-theme='dark']) .ask-help-community-icon,
  :global(.dark) .ask-help-community-icon {
    background-color: #1f2937;
    color: #5865F2;
  }
  :global([data-theme='dark']) .ask-help-community-icon:hover,
  :global(.dark) .ask-help-community-icon:hover {
    background-color: #374151;
  }

  .ask-help-chat {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #ffffff;
    background-color: #111827;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s;
  }
  .ask-help-chat:hover {
    background-color: #1f2937;
  }
  :global([data-theme='dark']) .ask-help-chat,
  :global(.dark) .ask-help-chat {
    background-color: #ffffff;
    color: #111827;
  }
  :global([data-theme='dark']) .ask-help-chat:hover,
  :global(.dark) .ask-help-chat:hover {
    background-color: #f3f4f6;
  }
  .ask-help-chat-icon {
    flex-shrink: 0;
  }

  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .header {
      padding-inline-end: var(--sl-nav-pad-x);
    }
    .sidebar-pane {
      --sl-sidebar-visibility: visible;
      /* 2:5:2 비율 — 좌측 20rem 고정 (custom.css 로드 순서 무관) */
      width: 20rem;
      min-width: 20rem;
      max-width: 20rem;
      background-color: var(--sl-color-bg-sidebar);
    }
  }

  /* 2:5:2 비율 — content 영역 시작점 (좌측 20rem) */
  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .main-frame {
      padding-inline-start: 20rem;
    }
  }
</style>
